{
  "name": "prompt-lab",
  "private": true,
  "version": "1.7.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "check:node": "node scripts/require-node-22.mjs",
    "dev": "npm run check:node && npm run dev --prefix prompt-lab-extension",
    "build": "npm run check:node && npm run build --prefix prompt-lab-extension",
    "test": "npm run check:node && npm test --prefix prompt-lab-extension",
    "docs:lint": "npm run check:node && markdownlint-cli2",
    "docs:check": "npm run docs:lint",
    "test:notion-agent": "npm run check:node && node --test scripts/notion-docs-agent.test.mjs",
    "build:landing": "npm run check:node && node scripts/publish-landing.mjs",
    "notion:docs-agent": "npm run check:node && node scripts/notion-docs-agent.mjs",
    "publish:landing": "npm run build:landing",
    "deploy:preview": "npm run check:node && node scripts/vercel-deploy.mjs",
    "deploy:prod": "npm run check:node && node scripts/vercel-deploy.mjs --prod",
    "preflight": "npm run check:node && node scripts/preflight.mjs",
    "preflight:quick": "npm run check:node && node scripts/preflight.mjs --quick",
    "dashboard:update": "npm run check:node && node scripts/notionDashboardUpdate.mjs"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.18.1"
  }
}
