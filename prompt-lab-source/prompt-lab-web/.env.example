# Clerk authentication (hosted web only)
# Get your publishable key from https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Server-side Clerk auth for protected billing endpoints.
# CLERK_PUBLISHABLE_KEY is optional if you want the server to reuse
# VITE_CLERK_PUBLISHABLE_KEY instead.
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Stripe billing scaffold (hosted web only, test mode)
# Create a recurring test-mode Price in Stripe and paste the ID here.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...

# Stripe webhook signature verification.
# Get from Stripe Dashboard → Webhooks → Signing secret.
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional custom customer portal configuration.
# Leave blank to use the Stripe Dashboard default portal configuration.
STRIPE_PORTAL_CONFIGURATION_ID=bpc_...

# Vercel KV for entitlement storage (optional).
# Falls back to in-memory store when not configured.
# Provisioned automatically when you add Vercel KV to the project.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# env var redeploy trigger
