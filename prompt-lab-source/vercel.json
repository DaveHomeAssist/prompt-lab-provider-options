{
  "buildCommand": "npm install diff-match-patch && cd prompt-lab-web && npm install && npm run build",
  "installCommand": "echo 'root install handled in buildCommand'",
  "outputDirectory": "prompt-lab-web/dist",
  "framework": null,
  "rewrites": [
    { "source": "/embed", "destination": "/prompt-embed.html" },
    { "source": "/tools/embed", "destination": "/tools/prompt-embed.html" },
    { "source": "/tools", "destination": "/tools/index.html" },
    { "source": "/tools/", "destination": "/tools/index.html" },
    { "source": "/app", "destination": "/app/index.html" },
    { "source": "/app/(.*)", "destination": "/app/index.html" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
