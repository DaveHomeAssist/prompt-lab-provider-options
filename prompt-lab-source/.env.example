# Prompt Lab — Environment Variables
# Copy this file to .env.local for local development.
# Set these in Vercel project settings for production.

# ── Clerk (Auth) ─────────────────────────────────────────────────────────────
# Required for hosted web auth. Extension and desktop do not use Clerk.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── Stripe (Billing) ────────────────────────────────────────────────────────
# Required for checkout, portal, and webhook endpoints.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: Stripe portal configuration ID for custom portal branding.
# STRIPE_PORTAL_CONFIGURATION_ID=bpc_...

# ── Vercel KV (Entitlement Storage) ─────────────────────────────────────────
# Required for durable entitlement persistence in production.
# Falls back to in-memory store when not set (dev/test only).
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...

# ── Notion (Bug Reports) ────────────────────────────────────────────────────
# Used by api/bug-report.js to post structured reports.
# NOTION_API_KEY=ntn_...
# NOTION_BUG_DB_ID=...
